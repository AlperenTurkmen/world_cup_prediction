# Supabase — server-only. Never import the service-role key into a Client Component.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin login
ADMIN_PASSWORD=
# Random string used to sign the admin cookie (e.g. `openssl rand -hex 32`)
AUTH_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Results auto-sync (football-data.org) — see docs/RESULTS_SYNC.md
# Free API key from https://www.football-data.org/
FOOTBALL_DATA_API_KEY=
# Bearer token the external scheduler presents to POST /api/sync (e.g. `openssl rand -hex 32`)
SYNC_SECRET=
